<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0D1117"
    android:padding="40dp">

    <!-- Battery Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔋"
        android:textSize="72sp"
        android:layout_marginBottom="8dp" />

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="วินิจฉัยระบบแบตเตอรี่"
        android:textColor="#E6EDF3"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deepal L07 / S07"
        android:textColor="#58A6FF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="50 เคส · Launch X431 Pro · OBD2 Diagnostic"
        android:textColor="#8B949E"
        android:textSize="13sp"
        android:layout_marginBottom="52dp" />

    <!-- Web Grid Mode Button -->
    <Button
        android:id="@+id/btn_web"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="📋  โหมด Grid — ค้นหา &amp; กรองเคส"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#1A7FD4"
        android:layout_marginBottom="16dp"
        android:cornerRadius="14dp" />

    <!-- Flipbook Mode Button -->
    <Button
        android:id="@+id/btn_flipbook"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="📖  โหมด Flipbook — อ่านทีละหน้า"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#177C4B"
        android:cornerRadius="14dp" />

    <!-- Supported by -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="supported by MQ Square Co.,Ltd"
        android:textColor="#58A6FF"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="40dp" />

    <!-- Version -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textColor="#484F58"
        android:textSize="11sp"
        android:layout_marginTop="6dp" />

</LinearLayout>
